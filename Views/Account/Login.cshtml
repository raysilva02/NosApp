@model Nos.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Entrar"; Layout = null;
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Entrar - Nos</title>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#E53935" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Nos" />
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js')
                .then(() => console.log('SW registrado'))
                .catch(e => console.error('SW erro:', e));
        }
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="nos-auth-bg">
    <div class="container d-flex justify-content-center align-items-center min-vh-100">
        <div class="nos-auth-card">
            <div class="nos-auth-header text-center mb-4">
                <div class="nos-logo-circle mb-3"><i class="bi bi-heart-fill"></i></div>
                <h1 class="nos-brand-title">Nos</h1>
                <p class="nos-brand-subtitle">Cuidado e Conexao</p>
            </div>
            <form asp-controller="Account" asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                <div class="mb-4">
                    <label asp-for="Telefone" class="nos-label"></label>
                    <div class="input-group">
                        <span class="input-group-text nos-input-icon"><i class="bi bi-telephone-fill"></i></span>
                        <input asp-for="Telefone" class="form-control nos-input" placeholder="(00) 00000-0000" />
                    </div>
                    <span asp-validation-for="Telefone" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Senha" class="nos-label"></label>
                    <div class="input-group">
                        <span class="input-group-text nos-input-icon"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="Senha" class="form-control nos-input" placeholder="Sua senha" />
                    </div>
                    <span asp-validation-for="Senha" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="LembrarMe" class="form-check-input nos-check" type="checkbox" checked />
                        <label asp-for="LembrarMe" class="form-check-label nos-label">Manter conectado</label>
                    </div>
                </div>
                <button type="submit" class="btn nos-btn-primary w-100 mb-3">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                </button>
            </form>
            <div class="text-center mt-3">
                <p class="nos-text-muted mb-2">Ainda nao tem conta?</p>
                <div class="d-flex gap-2 justify-content-center">
                    <a asp-controller="Account" asp-action="RegisterIdoso" class="btn nos-btn-outline-sm"><i class="bi bi-person-plus me-1"></i>Sou Idoso</a>
                    <a asp-controller="Account" asp-action="RegisterCuidador" class="btn nos-btn-outline-sm"><i class="bi bi-person-badge me-1"></i>Sou Cuidador</a>
                </div>
            </div>
        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
