@model Nos.ViewModels.RegisterCuidadorViewModel
@{ViewData["Title"]="Cadastro Cuidador";Layout=null;}
<!DOCTYPE html><html lang="pt-BR"><head>
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#E53935" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Nos" />
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js')
                .then(() => console.log('SW registrado'))
                .catch(e => console.error('SW erro:', e));
        }
    </script>

<meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>Cadastro Cuidador - Nos</title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"/><link rel="stylesheet" href="~/css/site.css"/></head><body class="nos-auth-bg">
<div class="container d-flex justify-content-center align-items-center min-vh-100 py-4"><div class="nos-auth-card"><div class="text-center mb-4"><div class="nos-logo-circle mb-3" style="background:#FFB300;"><i class="bi bi-person-badge-fill"></i></div><h2 class="nos-brand-title">Cadastro de Cuidador</h2><p class="nos-brand-subtitle">Crie sua conta no Nos</p></div>
<form asp-controller="Account" asp-action="RegisterCuidador" method="post"><div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
<div class="mb-3"><label asp-for="NomeCompleto" class="nos-label"></label><div class="input-group"><span class="input-group-text nos-input-icon"><i class="bi bi-person-fill"></i></span><input asp-for="NomeCompleto" class="form-control nos-input" placeholder="Seu nome completo"/></div><span asp-validation-for="NomeCompleto" class="text-danger small"></span></div>
<div class="mb-3"><label asp-for="Telefone" class="nos-label"></label><div class="input-group"><span class="input-group-text nos-input-icon"><i class="bi bi-telephone-fill"></i></span><input asp-for="Telefone" class="form-control nos-input" placeholder="(00) 00000-0000"/></div><span asp-validation-for="Telefone" class="text-danger small"></span></div>
<div class="mb-3"><label asp-for="Senha" class="nos-label"></label><div class="input-group"><span class="input-group-text nos-input-icon"><i class="bi bi-lock-fill"></i></span><input asp-for="Senha" class="form-control nos-input" placeholder="Minimo 6 caracteres"/></div><span asp-validation-for="Senha" class="text-danger small"></span></div>
<div class="mb-4"><label asp-for="ConfirmarSenha" class="nos-label"></label><div class="input-group"><span class="input-group-text nos-input-icon"><i class="bi bi-lock-fill"></i></span><input asp-for="ConfirmarSenha" class="form-control nos-input" placeholder="Repita a senha"/></div><span asp-validation-for="ConfirmarSenha" class="text-danger small"></span></div>
<button type="submit" class="btn nos-btn-yellow w-100 mb-3"><i class="bi bi-person-check me-2"></i>Cadastrar como Cuidador</button></form>
<div class="text-center mt-3"><a asp-controller="Account" asp-action="Login" class="nos-link"><i class="bi bi-arrow-left me-1"></i>Ja tenho conta</a></div></div></div>
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation/1.19.5/jquery.validate.min.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script></body></html>