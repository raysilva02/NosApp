@model Nos.Models.Cuidador
@{ViewData["Title"]="Meus Pacientes";}
<div class="d-flex justify-content-between align-items-center mb-4"><h2 class="nos-page-title"><i class="bi bi-people-fill me-2"></i>Meus Pacientes</h2><a asp-controller="Paciente" asp-action="AdicionarPaciente" class="btn nos-btn-primary"><i class="bi bi-person-plus me-2"></i>Adicionar Paciente</a></div>
@if(Model?.Relacionamentos!=null&&Model.Relacionamentos.Any()){<div class="row g-4">@foreach(var rel in Model.Relacionamentos){<div class="col-12 col-md-6"><div class="nos-paciente-card"><div class="d-flex align-items-center mb-3"><div class="nos-avatar me-3" style="background:#FFCDD2;"><i class="bi bi-person-fill" style="color:#E53935;"></i></div><div><h5 class="mb-0">@rel.Idoso?.ApplicationUser?.NomeCompleto</h5><small class="text-muted"><i class="bi bi-telephone me-1"></i>@rel.Idoso?.ApplicationUser?.PhoneNumber</small></div></div>
<div class="nos-remedios-mini mb-3"><p class="nos-label mb-2"><i class="bi bi-capsule me-1"></i>Remedios (@(rel.Idoso?.Remedios?.Count()??0)):</p>@if(rel.Idoso?.Remedios!=null&&rel.Idoso.Remedios.Any()){@foreach(var rem in rel.Idoso.Remedios.Take(3)){<span class="nos-remedio-tag"><i class="bi bi-capsule me-1"></i>@rem.Nome - @rem.Horario</span>}@if(rel.Idoso.Remedios.Count()>3){<span class="nos-remedio-tag-more">+@(rel.Idoso.Remedios.Count()-3) mais</span>}}else{<span class="text-muted small">Nenhum remedio</span>}</div>
<div class="d-flex gap-2"><a asp-controller="Chat" asp-action="CuidadorChat" asp-route-relacionamentoId="@rel.Id" class="btn nos-btn-chat flex-grow-1"><i class="bi bi-chat-dots-fill me-1"></i>Chat</a><a asp-controller="Remedio" asp-action="Create" asp-route-idosoId="@rel.IdosoId" class="btn nos-btn-yellow-sm"><i class="bi bi-plus-circle me-1"></i>Remedio</a></div></div></div>}</div>}
else{<div class="nos-empty-state"><i class="bi bi-people display-3 mb-3"></i><h4>Nenhum paciente vinculado</h4><a asp-controller="Paciente" asp-action="AdicionarPaciente" class="btn nos-btn-primary mt-2"><i class="bi bi-person-plus me-2"></i>Adicionar Paciente</a></div>}