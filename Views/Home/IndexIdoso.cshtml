@{ViewData["Title"]="Inicio";var idoso=ViewBag.Idoso as Nos.Models.Idoso;var nome=ViewBag.NomeUsuario as string;}
<div class="nos-hero-card mb-4"><div class="d-flex align-items-center"><div class="nos-avatar-large me-3"><i class="bi bi-person-fill"></i></div><div><h2 class="mb-0">Ola, @nome!</h2><p class="mb-0 opacity-75">O que voce precisa hoje?</p></div></div></div>
<div class="row g-4">
<div class="col-12"><div class="nos-section-card"><div class="nos-section-header"><i class="bi bi-chat-heart-fill me-2"></i>Meus Cuidadores</div><div class="nos-section-body">
@if(idoso?.Relacionamentos!=null&&idoso.Relacionamentos.Any()){<div class="row g-3">@foreach(var rel in idoso.Relacionamentos){<div class="col-12 col-md-6"><div class="nos-cuidador-card"><div class="d-flex align-items-center mb-3"><div class="nos-avatar me-3"><i class="bi bi-person-badge-fill"></i></div><div><h5 class="mb-0">@rel.Cuidador?.ApplicationUser?.NomeCompleto</h5><small class="text-muted">Desde @rel.DataInicio.ToString("dd/MM/yyyy")</small></div></div><a asp-controller="Chat" asp-action="IdosoChat" asp-route-relacionamentoId="@rel.Id" class="btn nos-btn-chat w-100"><i class="bi bi-chat-dots-fill me-2"></i>Abrir Chat</a></div></div>}</div>}
else{<div class="nos-empty-state"><i class="bi bi-people display-4 mb-3"></i><p>Nenhum cuidador vinculado ainda.</p><small>Peca ao seu cuidador para adiciona-lo pelo numero de telefone.</small></div>}
</div></div></div>
<div class="col-12"><div class="nos-section-card"><div class="nos-section-header nos-header-yellow"><i class="bi bi-capsule-pill me-2"></i>Meus Remedios</div><div class="nos-section-body">
@if(idoso?.Remedios!=null&&idoso.Remedios.Any()){<div class="row g-3">@foreach(var rem in idoso.Remedios.OrderBy(r=>r.Horario)){<div class="col-12 col-md-6"><div class="nos-remedio-card"><div class="d-flex justify-content-between align-items-start mb-2"><h5 class="nos-remedio-nome"><i class="bi bi-capsule me-2"></i>@rem.Nome</h5><span class="nos-badge-horario"><i class="bi bi-clock me-1"></i>@rem.Horario</span></div><p class="nos-remedio-dose mb-1"><strong>Dose:</strong> @rem.Dose</p>@if(!string.IsNullOrEmpty(rem.Descricao)){<p class="nos-remedio-desc mb-0">@rem.Descricao</p>}</div></div>}</div>}
else{<div class="nos-empty-state"><i class="bi bi-capsule display-4 mb-3"></i><p>Nenhum remedio cadastrado ainda.</p></div>}
</div></div></div></div>