@model Nos.ViewModels.RemedioCreateViewModel
@{ViewData["Title"]="Cadastrar Remedio";}
<div class="row justify-content-center"><div class="col-12 col-md-8 col-lg-6"><div class="nos-form-card"><div class="nos-form-header nos-header-yellow"><i class="bi bi-capsule-pill me-2"></i>Novo Remedio</div><div class="nos-form-body">
<div class="nos-patient-badge mb-4"><i class="bi bi-person-fill me-2"></i>Paciente: <strong>@Model.IdosoNome</strong></div>
<form asp-controller="Remedio" asp-action="Create" method="post"><input type="hidden" asp-for="IdosoId"/><input type="hidden" asp-for="IdosoNome"/>
<div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
<div class="mb-3"><label asp-for="Nome" class="nos-label"></label><div class="input-group"><span class="input-group-text nos-input-icon"><i class="bi bi-capsule"></i></span><input asp-for="Nome" class="form-control nos-input" placeholder="Ex: Losartana"/></div><span asp-validation-for="Nome" class="text-danger small"></span></div>
<div class="mb-3"><label asp-for="Horario" class="nos-label"></label><div class="input-group"><span class="input-group-text nos-input-icon"><i class="bi bi-clock-fill"></i></span><input asp-for="Horario" class="form-control nos-input" type="time"/></div><span asp-validation-for="Horario" class="text-danger small"></span></div>
<div class="mb-3"><label asp-for="Dose" class="nos-label"></label><div class="input-group"><span class="input-group-text nos-input-icon"><i class="bi bi-droplet-half"></i></span><input asp-for="Dose" class="form-control nos-input" placeholder="Ex: 1 comprimido de 50mg"/></div><span asp-validation-for="Dose" class="text-danger small"></span></div>
<div class="mb-4"><label asp-for="Descricao" class="nos-label"></label><textarea asp-for="Descricao" class="form-control nos-input" rows="3" placeholder="Informacoes adicionais (opcional)..."></textarea></div>
<div class="d-flex gap-2"><button type="submit" class="btn nos-btn-yellow flex-grow-1"><i class="bi bi-check-circle me-2"></i>Salvar Remedio</button><a asp-controller="Paciente" asp-action="Index" class="btn nos-btn-outline-sm">Cancelar</a></div>
</form></div></div></div></div>
@section Scripts{<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation/1.19.5/jquery.validate.min.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>}