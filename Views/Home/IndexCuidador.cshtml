@{ViewData["Title"]="Inicio";var cuidador=ViewBag.Cuidador as Nos.Models.Cuidador;var nome=ViewBag.NomeUsuario as string;}
<div class="nos-hero-card nos-hero-cuidador mb-4"><div class="d-flex align-items-center"><div class="nos-avatar-large me-3" style="background:#FFB300;"><i class="bi bi-person-badge-fill"></i></div><div><h2 class="mb-0">Ola, @nome!</h2><p class="mb-0 opacity-75">Painel do Cuidador</p></div></div></div>
<div class="row g-3 mb-4"><div class="col-6 col-md-3"><a asp-controller="Paciente" asp-action="Index" class="nos-quick-action"><i class="bi bi-people-fill"></i><span>Meus Pacientes</span></a></div><div class="col-6 col-md-3"><a asp-controller="Paciente" asp-action="AdicionarPaciente" class="nos-quick-action nos-qa-yellow"><i class="bi bi-person-plus-fill"></i><span>Adicionar Paciente</span></a></div></div>
<div class="nos-section-card"><div class="nos-section-header"><i class="bi bi-chat-heart-fill me-2"></i>Pacientes -- Chats Rapidos</div><div class="nos-section-body">
@if(cuidador?.Relacionamentos!=null&&cuidador.Relacionamentos.Any()){<div class="row g-3">@foreach(var rel in cuidador.Relacionamentos){<div class="col-12 col-md-6"><div class="nos-cuidador-card"><div class="d-flex align-items-center mb-3"><div class="nos-avatar me-3" style="background:#FFCDD2;"><i class="bi bi-person-fill" style="color:#E53935;"></i></div><div><h5 class="mb-0">@rel.Idoso?.ApplicationUser?.NomeCompleto</h5><small class="text-muted">Desde @rel.DataInicio.ToString("dd/MM/yyyy")</small></div></div><div class="d-flex gap-2"><a asp-controller="Chat" asp-action="CuidadorChat" asp-route-relacionamentoId="@rel.Id" class="btn nos-btn-chat flex-grow-1"><i class="bi bi-chat-dots-fill me-1"></i>Chat</a><a asp-controller="Remedio" asp-action="Create" asp-route-idosoId="@rel.IdosoId" class="btn nos-btn-yellow-sm"><i class="bi bi-capsule-pill me-1"></i>Remedio</a></div></div></div>}</div>}
else{<div class="nos-empty-state"><i class="bi bi-people display-4 mb-3"></i><p>Nenhum paciente ainda.</p><a asp-controller="Paciente" asp-action="AdicionarPaciente" class="btn nos-btn-primary mt-2"><i class="bi bi-person-plus me-2"></i>Adicionar Paciente</a></div>}
</div></div>